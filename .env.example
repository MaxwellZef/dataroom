# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Google Cloud API key with the Drive API enabled (restrict it to Drive API in the console)
GOOGLE_API_KEY=

# Comma-separated Telegram numeric user IDs allowed to use the bot.
# Leave empty on first run: the bot will reply to /start with your user ID
# so you can copy it in here, then restart the bot.
ALLOWED_TELEGRAM_USER_IDS=

# Where the file catalog is stored. Defaults to a local SQLite file.
# For a hosted deployment without a persistent disk, point this at a
# managed Postgres instance instead, e.g:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dataroom
DATABASE_URL=sqlite:///dataroom.db

# Port for the health-check HTTP endpoint (required by some free hosts
# that expect a web service to bind a port).
PORT=8080
